    PROC main()
        TPErase;
        TPWrite "Drawing Demo";
        TPReadFK MyChoice, "What do you want to write or draw?", "Square", "D_Shape", "Circle", "Salford", "MyName";
        TEST MyChoice
        CASE 1:
         Square;
        CASE 2:
         D_Shape;
        CASE 3:
         Circle;
        CASE 4:
         Salford;
        CASE 5:
         MyName;
        ENDTEST
    ENDPROC
PROC Square()
        MoveJ startpoint, v100, z50, toolpen\WObj:=wobjshapes;
        MoveJ stp_sqr, v100, z50, toolpen\WObj:=wobjshapes;
        MoveL sqr1, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL sqr2, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL sqr3, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL sqr4, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL sqr5, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL sqr_end_up, v100, z50, toolpen\WObj:=wobjshapes;
ENDPROC
PROC D_Shape()
        WaitTime 2;
        MoveJ Dshp_start_up, v100, z50, toolpen\WObj:=wobjshapes;
        MoveL Dshp_pt1, v100, z50, toolpen\WObj:=wobjshapes;
        MoveL Dshp_pt2, v100, z50, toolpen\WObj:=wobjshapes;
        MoveL Dshp_pt3, v100, z50, toolpen\WObj:=wobjshapes;
        MoveC Dshp_crv1, Dshp_crv2, v100, z10, toolpen\WObj:=wobjshapes;
        MoveL Dshp_pt4, v100, fine, toolpen\WObj:=wobjshapes;
        MoveL Dshp_end_up, v100, z50, toolpen\WObj:=wobjshapes;
ENDPROC
PROC Circle()
        WaitTime 2;
        MoveL Crcl_start_up, v100, z50, toolpen\WObj:=wobjshapes;
        MoveL Crcl_start_pt1, v100, z50, toolpen\WObj:=wobjshapes;
        MoveC Crcl_pt2, Crcl_pt3, v100, z10, toolpen\WObj:=wobjshapes;
        MoveC Crcl_pt4, Crcl_pt5, v100, z10, toolpen\WObj:=wobjshapes;
        MoveL Crcl_end_up, v100, z50, toolpen\WObj:=wobjshapes;
        WaitTime 2;
ENDPROC
PROC Salford()
