        MoveC S_p5, S_p6, v100, fine, toolpen\WObj:=wobjname;
        MoveL S_p6endindup, v100, fine, toolpen\WObj:=wobjname;
        WaitTime 2;
        MoveL endmove1, v100, fine, toolpen\WObj:=wobjname;
        MoveL endmove2, v100, fine, toolpen\WObj:=wobjname;
        MoveL lastmove, v100, fine, toolpen\WObj:=wobjname;
ENDPROC
